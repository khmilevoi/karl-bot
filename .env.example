PORT=3000
BOT_TOKEN=***
BOT_NAME=Bot
OPENAI_KEY=***
NODE_ENV=development
DATABASE_URL=file://./data/memory.db
LOG_LEVEL=debug
ADMIN_CHAT_ID=***
# Defaults to true only when NODE_ENV=development; set explicitly to override.
LOG_PROMPTS=false
VOICE_WORKER_CONCURRENCY=1
VOICE_WORKER_POLL_INTERVAL_MS=1000
VOICE_WORKER_LOCK_MS=300000
VOICE_WORKER_MAX_ATTEMPTS=3
VOICE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VOICE_MAX_DURATION_SECONDS=120
# Fact-checking feature (disabled by default)
FACT_CHECK_ENABLED=false
FACT_CHECK_HOURLY_CRON=0 0 * * * *
FACT_CHECK_DAILY_STATS_CRON=0 0 9 * * *
FACT_CHECK_WEEKLY_STATS_CRON=0 0 9 * * 1
FACT_CHECK_MONTHLY_STATS_CRON=0 0 9 1 * *
FACT_CHECK_TIMEZONE=Europe/Warsaw
FACT_CHECK_MAX_MESSAGES_PER_BATCH=200
FACT_CHECK_MAX_CLAIMS_PER_BATCH=40
FACT_CHECK_MAX_HISTORY_CONTEXT_MESSAGES=100
FACT_CHECK_MAX_SOURCE_SEARCHES_PER_BATCH=20
FACT_CHECK_MAX_SOURCES_PER_FINDING=5
FACT_CHECK_MAX_DISPLAYED_SOURCES_PER_FINDING=3
FACT_CHECK_MAX_FINDINGS_PER_DIGEST_MESSAGE=10
FACT_CHECK_VERIFICATION_CONFIDENCE_THRESHOLD=0.75
