{
  "name": "karl-bot",
  "version": "1.0.0",
  "description": "бот Карл",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "rsbuild build",
    "start": "node dist/index.js",
    "dev": "nodemon -L --watch src --ext ts --exec \"rsbuild build && node dist/index.js\"",
    "dev:worker": "nodemon -L --watch src --ext ts --exec \"rsbuild build && node dist/voice-worker.js\"",
    "docker:build:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml build",
    "docker:build:prod": "docker compose -f docker-compose.yml build",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:prod": "docker compose -f docker-compose.yml up --build -d",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "job": "pnpm build && node dist/manual-job.js",
    "job:state-evolution": "pnpm build && node dist/manual-job.js state-evolution",
    "job:topic-of-day": "pnpm build && node dist/manual-job.js topic-of-day",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "type:check": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "migration:up": "node scripts/pre-migrate.js && node dist/migrate.js up",
    "migration:down": "node scripts/pre-migrate.js && node dist/migrate.js down",
    "migration:check": "node scripts/pre-migrate.js && node dist/migrate.js check",
    "voice-worker": "node dist/voice-worker.js"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/menu": "^1.3.1",
    "dotenv": "^17.1.0",
    "grammy": "^1.43.0",
    "inversify": "^7.0.0-alpha.5",
    "node-cron": "^4.2.1",
    "openai": "^6.41.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.1",
    "reflect-metadata": "^0.2.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.8",
    "@rspack/core": "^2.0.5",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^3.2.4",
    "nodemon": "^3.1.10",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f"
}
